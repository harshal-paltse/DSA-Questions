# Write your MySQL query statement below
select b.book_id, b.title, b.author, b.genre, b.pages, max(rs.session_rating) - min(rs.session_rating) as rating_spread, round(sum(session_rating != 3)/count(*), 2) as polarization_score 
from books b left join reading_sessions rs on b.book_id = rs.book_id 
group by b.book_id having count(*) >= 5 and max(rs.session_rating) >= 4 and min(rs.session_rating) <= 2
order by polarization_score desc, b.title desc;
